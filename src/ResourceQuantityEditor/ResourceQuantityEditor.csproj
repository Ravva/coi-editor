<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" Condition="false" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{C2F1B573-75B2-4B4E-9E17-710239C78A3E}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>ResourceQuantityEditor</RootNamespace>
    <AssemblyName>ResourceQuantityEditor</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <NoStdLib>true</NoStdLib>
    <COI_ROOT Condition=" '$(COI_ROOT)' == '' ">C:\Games\Captain of Industry\game</COI_ROOT>
    <COI_MODS Condition=" '$(COI_MODS)' == '' ">$(APPDATA)\Captain of Industry\Mods</COI_MODS>
    <DeployToModsFolder>true</DeployToModsFolder>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ResourceQuantityEditor.cs" />
    <Compile Include="ProductHelper.cs" />
    <Compile Include="GlobalResourceEditorService.cs" />
    <Compile Include="SandboxFeatureService.cs" />
    <Compile Include="TreeRangeRemovalService.cs" />
    <Compile Include="ResourceQuantityEditorUi.cs" />
    <Compile Include="Patches\InstantCargoShipsPatch.cs" />
    <Compile Include="Patches\UnlimitedDesignationsPatch.cs" />
    <Compile Include="Patches\SettlementCheatsPatch.cs" />
    <Compile Include="Patches\HealthCheatsPatch.cs" />
    <Compile Include="Services\VisualTweaksService.cs" />
		<Compile Include="Services\OptionsStateService.cs" />
		<Compile Include="Services\LocomotiveEditorService.cs" />
	  </ItemGroup>

  <ItemGroup>
    <None Include="manifest.json" />
    <None Include="config.json" />
    <None Include="readme.txt" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="mscorlib">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\mscorlib.dll</HintPath>
    </Reference>
    <Reference Include="netstandard">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\netstandard.dll</HintPath>
    </Reference>
    <Reference Include="System">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\System.dll</HintPath>
    </Reference>
    <Reference Include="System.Core">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\System.Core.dll</HintPath>
    </Reference>
    <Reference Include="Mafi">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.dll</HintPath>
    </Reference>
    <Reference Include="Mafi.Core">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Core.dll</HintPath>
    </Reference>
    <Reference Include="Mafi.Base">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Base.dll</HintPath>
    </Reference>
    <Reference Include="Mafi.Unity">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Unity.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.IMGUIModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.InputLegacyModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.TextRenderingModule">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.TextRenderingModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.UIElementsModule">
      <HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.UIElementsModule.dll</HintPath>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(COI_MODS)\COIExtended.Cheats\0Harmony.dll</HintPath>
    </Reference>
  </ItemGroup>

  <Target Name="ValidateCoiRoot" BeforeTargets="BeforeBuild">
    <Error Condition="!Exists('$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Core.dll')" Text="COI_ROOT must point to the game folder that contains Captain of Industry_Data\Managed. Current value: $(COI_ROOT)" />
  </Target>

  <Target Name="DeployToModsFolder" AfterTargets="Build" Condition=" '$(DeployToModsFolder)' == 'true' ">
    <MakeDir Directories="$(COI_MODS)\$(AssemblyName)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(COI_MODS)\$(AssemblyName)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).pdb" DestinationFolder="$(COI_MODS)\$(AssemblyName)" Condition="Exists('$(OutputPath)$(AssemblyName).pdb')" />
    <Copy SourceFiles="$(OutputPath)0Harmony.dll" DestinationFolder="$(COI_MODS)\$(AssemblyName)" Condition="Exists('$(OutputPath)0Harmony.dll')" />
    <Copy SourceFiles="manifest.json;config.json;readme.txt" DestinationFolder="$(COI_MODS)\$(AssemblyName)" />
  </Target>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
